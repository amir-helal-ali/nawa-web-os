      "meta": {
        "title": "NAWA + SvelteKit",
        "description": "SvelteKit app embedded in a Rust binary — no Node.js at runtime"
      },
      "is_endpoint": false,
      "ssr_wasm": null,
      "layout": null
    },
    {
      "pattern": "/about",
      "methods": ["GET"],
      "prerendered_html": "about.html",
      "hydration_js": "about.js",
      "requires_auth": false,
      "admin_only": false,
      "meta": {
        "title": "About — NAWA SvelteKit",
        "description": "About this revolutionary integration"
      },
      "is_endpoint": false,
      "ssr_wasm": null,
      "layout": null
    },
    {
      "pattern": "/dashboard",
      "methods": ["GET"],
      "prerendered_html": null,
      "hydration_js": "dashboard.js",
      "requires_auth": true,
      "admin_only": false,
      "meta": {
        "title": "Dashboard — NAWA SvelteKit",
