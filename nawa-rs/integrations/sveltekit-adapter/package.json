{
  "name": "adapter-nawa",
  "version": "0.1.0-alpha",
  "description": "SvelteKit adapter for NAWA Web Operating System — embeds SvelteKit apps in a Rust binary (no Node.js at runtime)",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "adapter",
    "nawa",
    "rust",
    "ssr",
    "zero-copy",
    "embedded",
    "binary"
  ],
  "author": "NAWA Project",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/amir-helal-ali/nawa-web-os",
    "directory": "nawa-rs/integrations/sveltekit-adapter"
  },
  "homepage": "https://nawa.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "scripts": {
    "test": "node test.js"
  }
}
